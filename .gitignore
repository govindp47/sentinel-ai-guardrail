# =============================================================================
# SentinelAI Guardrail — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/

# Virtual environments
.venv/
venv/
env/

# uv
.uv/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
.dmypy.json

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.xml

# -----------------------------------------------------------------------------
# Environment — NEVER commit secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# Application data (runtime, not source)
# -----------------------------------------------------------------------------
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# FAISS indexes
*.faiss
*.index

# HuggingFace / SentenceTransformer model cache
.cache/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Compose override files with local secrets
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/*.local

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Alembic
# -----------------------------------------------------------------------------
# Keep versions/ tracked; ignore generated but uncommitted upgrade scripts
# (remove this if you want all migration files tracked — recommended)
# alembic/versions/*.py

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
