# =============================================================================
# SentinelAI Guardrail — Environment Variables
# =============================================================================
# Copy this file to .env and populate values for your environment.
# All variables are optional unless marked [REQUIRED].
# Defaults match local development with Ollama running on localhost.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Runtime environment. One of: development | staging | production
# Controls log level defaults, debug behaviour, and CORS origins.
# Type: str | Default: development
APP_ENV=development

# Host address the Uvicorn server binds to.
# Type: str | Default: 0.0.0.0
APP_HOST=0.0.0.0

# TCP port the Uvicorn server listens on.
# Type: int | Default: 8000
APP_PORT=8000

# Number of Uvicorn worker processes.
# Keep at 1 for SQLite. Increase for PostgreSQL deployments.
# Type: int | Default: 1
APP_WORKERS=1

# Enable FastAPI debug mode (detailed tracebacks in HTTP responses).
# NEVER set to true in production.
# Type: bool | Default: false
DEBUG=false

# Logging level. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Type: str | Default: INFO
LOG_LEVEL=INFO

# Log output format. One of: json | console
# Use 'console' for local development readability.
# Type: str | Default: json
LOG_FORMAT=console

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins.
# The Vite dev server runs on :5173 by default.
# Type: list[str] | Default: ["http://localhost:5173","http://localhost:3000"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Whether to allow cookies/credentials in CORS requests.
# Type: bool | Default: true
CORS_ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# SQLAlchemy async database URL.
# SQLite (default):   sqlite+aiosqlite:///./sentinel.db
# PostgreSQL:         postgresql+asyncpg://user:pass@host:5432/dbname
# Type: str | Default: sqlite+aiosqlite:///./sentinel.db
DATABASE_URL=sqlite+aiosqlite:///./sentinel.db

# SQLAlchemy connection pool size. Ignored for SQLite.
# Type: int | Default: 5
DATABASE_POOL_SIZE=5

# Maximum connections above pool_size. Ignored for SQLite.
# Type: int | Default: 10
DATABASE_MAX_OVERFLOW=10

# Emit all SQL statements to the logger. Enable only for query debugging.
# Type: bool | Default: false
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Vector Store
# -----------------------------------------------------------------------------

# Vector store implementation. One of: faiss | chroma
# Type: str | Default: faiss
VECTOR_STORE_BACKEND=faiss

# Directory where per-KB FAISS index files are persisted.
# Type: str | Default: ./data/faiss_indexes
FAISS_INDEX_DIR=./data/faiss_indexes

# ChromaDB server host. Only used when VECTOR_STORE_BACKEND=chroma.
# Type: str | Default: localhost
CHROMA_HOST=localhost

# ChromaDB server port. Only used when VECTOR_STORE_BACKEND=chroma.
# Type: int | Default: 8001
CHROMA_PORT=8001

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------

# SentenceTransformers model name for embedding document chunks and claims.
# Options: all-MiniLM-L6-v2 (fast, ~80MB) | BAAI/bge-small-en-v1.5 (higher quality, ~120MB)
# Downloaded to HuggingFace cache on first use.
# Type: str | Default: all-MiniLM-L6-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Torch device for embedding inference. One of: cpu | cuda | mps
# Type: str | Default: cpu
EMBEDDING_DEVICE=cpu

# Batch size for embedding document chunks during KB indexing.
# Type: int | Default: 32
EMBEDDING_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Ollama (local LLM)
# -----------------------------------------------------------------------------

# Base URL of the Ollama HTTP API.
# Type: str | Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model tag when caller does not specify a model.
# Must be pulled before use: ollama pull mistral
# Type: str | Default: mistral
OLLAMA_DEFAULT_MODEL=mistral

# HTTP timeout in seconds for Ollama inference requests.
# Type: int | Default: 120
OLLAMA_TIMEOUT=120

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------

# Default OpenAI model when caller selects openai provider without specifying a model.
# OpenAI API keys are passed per-request via X-Openai-Api-Key header — never stored.
# Type: str | Default: gpt-4o-mini
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# HTTP timeout in seconds for OpenAI API requests.
# Type: int | Default: 60
OPENAI_TIMEOUT=60

# -----------------------------------------------------------------------------
# Hallucination Detection
# -----------------------------------------------------------------------------

# Model used for claim extraction from LLM responses.
# Format: provider/model-name  (e.g. ollama/mistral, openai/gpt-4o-mini)
# Type: str | Default: ollama/mistral
CLAIM_EXTRACTION_MODEL=ollama/mistral

# Number of KB chunks retrieved per claim during hallucination verification.
# Higher values improve recall at the cost of latency.
# Type: int | Default: 5
CLAIM_VERIFICATION_TOP_K=5

# -----------------------------------------------------------------------------
# Safety / Toxicity
# -----------------------------------------------------------------------------

# Detoxify model variant. One of: original | unbiased | multilingual
# 'multilingual' supports non-English but requires ~250MB download.
# Type: str | Default: original
DETOXIFY_MODEL=original

# Detoxify toxicity score threshold [0.0, 1.0] above which a response is blocked.
# Higher values are more permissive.
# Type: float | Default: 0.7
TOXICITY_THRESHOLD=0.7

# Detoxify identity_attack + threat combined score threshold above which a response is blocked.
# Type: float | Default: 0.7
HATE_SPEECH_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Confidence Scoring
# -----------------------------------------------------------------------------

# Normalised confidence score [0.0, 1.0] at or above which the decision is ACCEPT.
# Type: float | Default: 0.70
CONFIDENCE_ACCEPT_THRESHOLD=0.70

# Normalised confidence score [0.0, 1.0] at or above which the decision is WARN.
# Scores below this trigger BLOCK or RETRY.
# Type: float | Default: 0.40
CONFIDENCE_WARN_THRESHOLD=0.40

# -----------------------------------------------------------------------------
# Chunking (KB indexing)
# -----------------------------------------------------------------------------

# Maximum token count per document chunk during KB indexing.
# Type: int | Default: 512
CHUNK_SIZE=512

# Token overlap between consecutive chunks. Preserves context at chunk boundaries.
# Type: int | Default: 64
CHUNK_OVERLAP=64

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------

# File storage backend for uploaded KB documents. Currently: local
# Type: str | Default: local
STORAGE_BACKEND=local

# Local filesystem directory for uploaded document storage.
# Type: str | Default: ./data/uploads
STORAGE_LOCAL_DIR=./data/uploads

# Maximum allowed file upload size in megabytes.
# Type: int | Default: 50
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# Security
# [REQUIRED] Override in staging and production.
# -----------------------------------------------------------------------------

# Secret key used for signing internal tokens.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Type: str | Default: change-me-in-production-use-a-random-32-byte-hex-string
SECRET_KEY=change-me-in-production-use-a-random-32-byte-hex-string

# HTTP header name used for server-to-server API key authentication.
# Type: str | Default: X-API-Key
API_KEY_HEADER=X-API-Key

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Enable per-IP rate limiting on the guardrail submit endpoint.
# Type: bool | Default: false
RATE_LIMIT_ENABLED=false

# Maximum requests per minute per IP when rate limiting is enabled.
# Type: int | Default: 60
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Background Workers
# -----------------------------------------------------------------------------

# Maximum concurrent KB document indexing tasks.
# Type: int | Default: 2
KB_INDEXING_MAX_CONCURRENCY=2

# -----------------------------------------------------------------------------
# WebSocket
# -----------------------------------------------------------------------------

# WebSocket ping/heartbeat interval in seconds.
# Type: int | Default: 30
WS_HEARTBEAT_INTERVAL=30

# Maximum concurrent WebSocket connections per guardrail request_id.
# Type: int | Default: 5
WS_MAX_CONNECTIONS_PER_REQUEST=5
